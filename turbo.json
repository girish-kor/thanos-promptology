{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": ["**/.env.*.local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "dependsOn": ["^db:push"]
    },
    "db:studio": {
      "cache": false
    }
  }
}
